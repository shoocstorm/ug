{
  "name": "ultragraph",
  "version": "0.1.0",
  "description": "High-Performance Knowledge Base Indexer",
  "main": "index.js",
  "napi": {
    "binaryName": "ultragraph",
    "platforms": [
      "aarch64-apple-darwin"
    ]
  },
  "scripts": {
    "build": "cargo build --release && mkdir -p ../.ug && cp target/release/ug ../.ug/ug",
    "postbuild": "napi build --output-dir ../.ug",
    "build:dev": "cargo build --profile dev-fast && mkdir -p ../.ug && cp target/dev-fast/ug ../.ug/ug",
    "postbuild:dev": "napi build --output-dir ../.ug",
    "test": "cargo test -- --nocapture"
  }
}