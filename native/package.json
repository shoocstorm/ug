{
  "name": "ultragraph-kb",
  "version": "0.1.0",
  "description": "High-Performance Knowledge Base Indexer",
  "main": "index.js",
  "napi": {
    "binaryName": "ultragraph-kb",
    "platforms": [
      "aarch64-apple-darwin"
    ]
  },
  "scripts": {
    "build": "cargo build --release",
    "postbuild": "napi build",
    "build:dev": "cargo build --profile dev-fast",
    "postbuild:dev": "napi build",
    "test": "cargo test -- --nocapture"
  }
}