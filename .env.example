# UltraGraph environment template. Copy to `.env` and fill in values.
# Loaded automatically by `ug` (via dotenvy) and `node --env-file=.env`.

# Destination selection — "overgraph" (default) or "neo4j".
# Comma-separated for fan-out ingest (e.g. "overgraph,neo4j").
# UG_DEST=overgraph

# OverGraph data directory
# UG_DB_PATH=./.ug/ugdb

# Neo4j (required when UG_DEST=neo4j)
# UG_NEO4J_URI=neo4j://localhost:7687
# UG_NEO4J_USER=neo4j
# UG_NEO4J_PASSWORD=
# UG_NEO4J_DATABASE=neo4j

# Embedder overrides (optional — defaults to in-process fastembed)
# UG_EMBED_BASE_URL=
# UG_EMBED_API_KEY=
# UG_EMBED_MODEL=
