# UltraGraph environment template. Copy to `.env` and fill in values.
# Loaded automatically by `ug` (via dotenvy) and `node --env-file=.env`.
#
# Prefer persisting defaults with `ug config set <key> <value>` (stored
# in $UG_HOME/config.json); env vars here override those saved values,
# and CLI flags override both.

# Destination selection — "overgraph" (default) or "neo4j".
# Comma-separated for fan-out ingest (e.g. "overgraph,neo4j").
# UG_DEST=overgraph

# Root for all generated project data (default: ~/.ug). Use an
# absolute path — env files don't expand `~`.
# UG_HOME=/absolute/path/to/.ug

# Project name for the MCP server (db = $UG_HOME/<project>/ugdb, repo
# root read from that project's project.json).
# UG_PROJECT=default

# OverGraph data directory — explicit override, wins over UG_PROJECT.
# UG_DB_PATH=/absolute/path/to/.ug/<project>/ugdb

# Neo4j (required when UG_DEST=neo4j)
# UG_NEO4J_URI=neo4j://localhost:7687
# UG_NEO4J_USER=neo4j
# UG_NEO4J_PASSWORD=
# UG_NEO4J_DATABASE=neo4j

# Embedder overrides (optional — defaults to in-process fastembed)
# UG_EMBED_BASE_URL=
# UG_EMBED_API_KEY=
# UG_EMBED_MODEL=

# Chat overrides (ug chat / POST /api/chat)
# UG_CHAT_BASE_URL=
# UG_CHAT_API_KEY=
# UG_CHAT_MODEL=
